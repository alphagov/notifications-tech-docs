                    "description": "Show templates of type SMS",
                    "value": "sms"
                },
                "email": {
                        "summary": "type=email",
                        "description": "Show templates of type email",
                        "value": "email"
                    },
                "letter": {
                        "summary": "type=letter",
                        "description": "Show templates of type email",
                        "value": "letter"
                    }  
            }    
