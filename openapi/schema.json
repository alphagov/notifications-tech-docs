                                    "description": "<p>Ensure that the value for the last line of the address is a real UK postcode or the name of a country outside the UK.</p"
                                }
                            }
                        }
                    ]
                }
            },
            "TemplatesRequestError": {
                "type": "object",
                "description": "If the request is successful, the response body is json and the status code is 200",
                "properties": {
                    "errors": [
                        {
                            "error": {
                                "type": "string",
                                "example": "ValidationError"
                            }
                        },
                        {
                            "message": {
                                "type": "string",
                                "example": "type pigeon is not one of [sms, email, letter, broadcast]",
                                "description": "Make sure that the provided type is one of: email, sms, letter"
                            }

                        }
                    ],
                    "status_code": {
                        "type": "integer",
                        "example" : 400
                    }
                }    
            },
            "AuthError": {
                "type": "array",
                "description": "Auth error response",
                "items": {
                    "oneOf": [
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "AuthError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Error: Your system clock must be accurate to within 30 seconds",
                                    "description": "Check your system clock"
                                }
                            }
                        },
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "AuthError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Invalid token: API key not found",
                                    "description": "<p>Use the correct API key. Refer to <a href='https://docs.notifications.service.gov.uk/rest-api.html#api-keys'>API keys</a> for more information</p>"
                                }
                            }
                        }
                    ]
                }
            },
            "SendLetterAuthError": {
                "type": "array",
                "description": "Auth error response",
                "items": {
                    "oneOf": [
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "AuthError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Error: Your system clock must be accurate to within 30 seconds",
                                    "description": "Check your system clock"
                                }
                            }
                        },
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "AuthError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Invalid token: API key not found",
                                    "description": "<p>Use the correct API key. Refer to <a href='https://docs.notifications.service.gov.uk/rest-api.html#api-keys'>API keys</a> for more information</p>"
                                }
                            }
                        },
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "BadRequestError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Can't send letters with a team API key",
                                    "description": "<p>Use the correct type of <a href='https://docs.notifications.service.gov.uk/rest-api.html#api-keys'>API key</a>.</p>"
                                }
                            }
                        }
                    ]
                }
            },
            "LimitError": {
                "type": "array",
                "description": "Rate or service limit error response",
                "items": {
                    "oneOf": [
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "RateLimitError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Invalid token: API key not found",
                                    "description": "<p>Refer to <a href='https://docs.notifications.service.gov.uk/rest-api.html#rate-limits'>API rate limits</a> for more information</p>"
                                }
                            }
                        },
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "TooManyRequestsError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Exceeded rate limit for key type TEAM/TEST/LIVE of 3000 requests per 60 seconds",
                                    "description": "<p>Refer to <a href='https://docs.notifications.service.gov.uk/rest-api.html#daily-limits'>service limits</a> for the limit number</p>"
                                }
                            }
                        }
                    ]
                }
            },
            "ServerError": {
                "type": "array",
                "description": "Rate or service limit error response",
                "items": {
                    "type": "object",
                    "properties": {
                        "error": {
                            "type": "string",
                            "example": "Exception"
                        },
                        "message": {
                            "type": "string",
                            "example": "Internal server error",
                            "description": "<p>Notify was unable to process the request, resend your notification.</p>"
                        }
                    }
                }
            }
        }
    }
}