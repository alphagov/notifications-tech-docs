        "/v2/notifications/letter": {
            "post": {
                "description": "You can use this endpoint to send letter.",
                "operationId": "sendLetter",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "./schema.json#/components/schemas/SendLetterRequest"
                            },
                            "examples": {
                                "Letter": {
                                    "value": {
                                        "template_id": "f33517ff-2a88-4f6e-b855-c550268ce08a",
                                        "personalisation": {
                                            "address_line_1": "The Occupier",
                                            "address_line_2": "123 High Street",
                                            "address_line_3": "Richmond upon Thames",
                                            "address_line_4": "Middlesex",
                                            "address_line_5": "SW14 6BF",
                                            "address_line_6": "string",
                                            "address_line_7": "string",
                                            "name": "John Smith",
                                            "application_id": "4134325",
                                            "required_documents": [
                                                "passport",
                                                "utility bill",
                                                "other id"
                                            ]
                                        },
                                        "reference": "STRING"
                                    }
                                },
                                "Precompiled Letter": {
                                    "value": {
                                        "reference": "STRING",
                                        "content": "base64EncodedPDFFile",
                                        "postage": "base64EncodedPDFFile"
                                    }
                                }
                            }
                        }
                    },
                    "description": "requestPayload",
                    "required": true
                },
                "responses": {
                    "201": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "schema.json#/components/schemas/SendLetterResponse"
                                },
                                "examples": {
                                    "Letter": {
                                        "value": {
                                            "id": "740e5834-3a29-46b4-9a6f-16142fde533a",
                                            "reference": "STRING",
                                            "content": {
                                                "subject": "SUBJECT TEXT",
                                                "body": "LETTER TEXT"
                                            },
                                            "uri": "https://api.notifications.service.gov.uk/v2/notifications/740e5834-3a29-46b4-9a6f-16142fde533a",
                                            "template": {
                                                "id": "f33517ff-2a88-4f6e-b855-c550268ce08a",
                                                "version": 1,
                                                "uri": "https://api.notifications.service.gov.uk/v2/template/f33517ff-2a88-4f6e-b855-c550268ce08a"
                                            },
                                            "scheduled_for": ""
                                        }
                                    },
                                    "Precompiled Letter": {
                                        "value": {
                                            "id": "740e5834-3a29-46b4-9a6f-16142fde533a",
                                            "reference": "your-letter-reference",
                                            "postage": "postage-you-have-set-or-None"
                                        }
                                    }
                                }
                            }
                        },
                        "description": "Created"
                    },
                    "400": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "schema.json#/components/schemas/SendLetterNotificaitonRequestError"
                                },
                                "examples": {
                                    "Trial Mode": {
                                        "value": [
                                            {
                                                "error": "BadRequestError",
                                                "message": "Can't send letters when service is in trial mode - see https://www.notifications.service.gov.uk/trial-mode"
                                            }
                                        ]
                                    },
                                    "Template Field": {
                                        "value": [
                                            {
                                                "error": "ValidationError",
                                                "message": "personalisation address_line_1 is a required property"
                                            }
                                        ]
                                    },
                                    "Invalid Postcode": {
                                        "value": [
                                            {
                                                "error": "ValidationError",
                                                "message": "Must be a real UK postcode"
                                            }
                                        ]
                                    },
                                    "Invalid Last Addressline": {
                                        "value": [
                                            {
                                                "error": "ValidationError",
                                                "message": "Last line of address must be a real UK postcode or another country"
                                            }
                                        ]
                                    },
                                    "Invalid Letter PDF": {
                                        "value": [
                                            {
                                                "error": "BadRequestError",
                                                "message": "Letter content is not a valid PDF"
                                            }
                                        ]
                                    },
                                    "Missing Refrence": {
                                        "value": [
                                            {
                                                "error": "ValidationError",
                                                "message": "reference is a required property"
                                            }
                                        ]
                                    },
                                    "Invalid Postage": {
                                        "value": [
                                            {
                                                "error": "ValidationError",
                                                "message": "postage invalid. It must be either first or second."
                                            }
                                        ]
                                    }
                                }
                            }
                        },
                        "description": "Bad request. Check the `message` in the response to find out why your request failed."
                    },
                    "403": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "schema.json#/components/schemas/SendLetterAuthError"
                                },
                                "examples": {
                                    "System Clock": {
                                        "value": [
                                            {
                                                "error": "AuthError",
                                                "message": "Error: Your system clock must be accurate to within 30 seconds"
                                            }
                                        ]
                                    },
                                    "API Key Missing": {
                                        "value": [
                                            {
                                                "error": "AuthError",
                                                "message": "Invalid token: API key not found"
                                            }
                                        ]
                                    },
                                    "Invalid API Key": {
                                        "value": [
                                            {
                                                "error": "BadRequestError",
                                                "message": "Can't send letters with a team API key"
                                            }
                                        ]
                                    }
                                }
                            }
                        },
                        "description": "Auth error. Check the `message` in the response to find out why your request failed."
                    },
                    "429": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "schema.json#/components/schemas/LimitError"
                                },
                                "examples": {
                                    "API Rate Limit": {
                                        "value": [
                                            {
                                                "error": "RateLimitError",
                                                "message": "Exceeded rate limit for key type TEAM/TEST/LIVE of 3000 requests per 60 seconds"
                                            }
                                        ]
                                    },
                                    "Service Limit": {
                                        "value": [
                                            {
                                                "error": "TooManyRequestsError",
                                                "message": "Exceeded send limits (LIMIT NUMBER) for today"
                                            }
                                        ]
                                    }
                                }
                            }
                        },
                        "description": "Rate or service limit error. Check the `message` in the response to find out why your request failed."
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "summary": "Send a letter",
                "tags": [
                    "Send a message"
                ]
            }
        }
    }
}