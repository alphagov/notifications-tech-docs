{
    "description": "All errors - usage example: {'$ref': 'errors.json#/ServerError'} (swap quotes for double quotes)",
    "components": {
        "schemas": {
            "GetReceivedTextMessageResponse": {
                "type": "object",
                "description": "The Send Text Message Response Payload",
                "properties": {
                    "id": {
                        "type": "string",
                        "example": "740e5834-3a29-46b4-9a6f-16142fde533a",
                        "required": true
                    },
                    "created_at": {
                        "type": "string",
                        "example": "STRING"
                    },
                    "service_id": {
                        "type": "string",
                        "example": "STRING"
                    },
                    "notify_number": {
                        "type": "string",
                        "example": "STRING"
                    },
                    "user_number": {
                        "type": "string",
                        "example": "STRING"
                    },
                    "content": {
                        "type": "string",
                        "example": "STRING"
                    }
                }
            },
            "GetReceivedTextMessagesResponse": {
                "type": "object",
                "description": "The Send Text Message Response Payload",
                "properties": {
                    "notifications": {
                        "type": "array",
                        "description": "Multiple message notifications",
                        "items": {
                            "type": "object",
                            "properties": {
                                "schema": {
                                    "$ref": "#/components/schemas/GetReceivedTextMessageResponse"
                                }
                            }
                        }
                    },
                    "links": {
                        "type": "object",
                        "description": "Pagination links",
                        "properties": {
                            "current": {
                                "type": "string",
                                "example": "/notifications?template_type=sms&status=delivered"
                            },
                            "id": {
                                "type": "string",
                                "example": "/notifications?other_than=last_id_in_list&template_type=sms&status=delivered"
                            }
                        }
                    }
                }
            },
            "GetMessageNoResultFoundError": {
                "type": "array",
                "description": "No result found error response",
                "items": {
                    "type": "object",
                    "properties": {
                        "error": {
                            "type": "string",
                            "example": "NoResultFound"
                        },
                        "message": {
                            "type": "string",
                            "example": "No result found",
                            "description": "<p>Check the notification ID</p>"
                        }
                    }
                }
            },
            "GetMessageValidationErrorError": {
                "type": "array",
                "description": "Validation error response",
                "items": {
                    "type": "object",
                    "properties": {
                        "error": {
                            "type": "string",
                            "example": "NoResultFound"
                        },
                        "message": {
                            "type": "string",
                            "example": "id is not a valid UUID",
                            "description": "<p>Check the notification ID</p>"
                        }
                    }
                }
            },
            "GetPDFLetterValidationErrorError": {
                "type": "array",
                "description": "Validation error response",
                "items": {
                    "oneOf": [
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "ValidationError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "id is not a valid UUID",
                                    "description": "<p>Check the notification ID</p>"
                                }
                            }
                        },
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "PDFNotReadyError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "PDF not available yet, try again later",
                                    "description": "<p>Wait for the letter to finish processing. This usually takes a few seconds</p>"
                                }
                            }
                        },
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "BadRequestError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "File did not pass the virus scan",
                                    "description": "<p>You cannot retrieve the contents of a letter that contains a virus</p>"
                                }
                            }
                        },
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "BadRequestError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "PDF not available for letters in technical-failure",
                                    "description": "<p>You cannot retrieve the contents of a letter in technical-failure</p>"
                                }
                            }
                        },
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "ValidationError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Notification is not a letter",
                                    "description": "<p>Check that you are looking up the correct notification</p>"
                                }
                            }
                        }
                    ]
                }
            },
            "AuthError": {
                "type": "array",
                "description": "Auth error response",
                "items": {
                    "oneOf": [
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "AuthError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Error: Your system clock must be accurate to within 30 seconds",
                                    "description": "Check your system clock"
                                }
                            }
                        },
                        {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "AuthError"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Invalid token: API key not found",
                                    "description": "<p>Use the correct API key. Refer to <a href='https://docs.notifications.service.gov.uk/rest-api.html#api-keys'>API keys</a> for more information</p>"
                                }
                            }
                        }
                    ]
                }
            }
        }
    }
}